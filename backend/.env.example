# ==============================================================================
# DevMind Backend Configuration
# ==============================================================================

DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD@localhost:5432/devmind

DEBUG=True

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ==============================================================================
# AI Provider Configuration
# ==============================================================================

# Primary provider
AI_PROVIDER=google

# Automatic failover order  
AI_PROVIDER_CHAIN=google,nvidia,groq,openrouter


# ==============================================================================
# AI Models
# ==============================================================================

# Google AI Studio
GOOGLE_MODEL_NAME=gemini-2.5-flash

# NVIDIA NIM
NVIDIA_MODEL_NAME=z-ai/glm-5.2

# Groq
GROQ_MODEL_NAME=moonshotai/kimi-k2-instruct

# OpenRouter
OPENROUTER_MODEL_NAME=google/gemini-2.5-flash


# ==============================================================================
# API Keys
# ==============================================================================

GOOGLE_API_KEY=

NVIDIA_API_KEY=

GROQ_API_KEY=

OPENROUTER_API_KEY=


# ==============================================================================
# Provider Base URLs
# ==============================================================================

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1


# ==============================================================================
# Model Configuration
# ==============================================================================

TEMPERATURE=0.2

MAX_TOKENS=3072

TIMEOUT=30

MAX_RETRIES=3


# ==============================================================================
# Retrieval Configuration
# ==============================================================================

RETRIEVAL_LIMIT=15


# ==============================================================================
# Prompt Versioning
# ==============================================================================

PROMPT_VERSION_REVIEW=1.0.0

PROMPT_VERSION_EXPLAIN=1.0.0

PROMPT_VERSION_TESTS=1.0.0

PROMPT_VERSION_BUGS=1.0.0


# ==============================================================================
# AI Cache
# ==============================================================================

AI_CACHE_ENABLED=True

AI_CACHE_DIR=temp/ai_cache


# ==============================================================================
# AI Features
# ==============================================================================

ENABLE_AI_FALLBACK=True


# ==============================================================================
# Logging
# ==============================================================================

LOG_LEVEL=INFO